OPENAI_API_KEY=your_openai_api_key
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
GITHUB_TOKEN=your_github_token

# Required in all environments (or use STORAGE_DATABASE_URL)
# Local Docker Postgres default:
DATABASE_URL=postgresql://spent:spent@localhost:5432/spent

# Optional override for platforms that provide a separate storage URL (e.g. Neon integration)
# STORAGE_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
